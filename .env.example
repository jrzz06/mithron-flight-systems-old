# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alternative name supported by lib/env.ts:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URL (required in production for auth redirects, emails, metadata)
# Local development:
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
# Production canonical host (used on Vercel when VERCEL_ENV=production):
MITHRON_PRODUCTION_HOST=https://final-mithron-deploy.vercel.app
# Optional: comma-separated extra allowed app hosts
# MITHRON_ALLOWED_APP_HOSTS=mithron.co
# Optional: comma-separated LAN IPs/hostnames so teammates can load the dev app (e.g. 192.168.1.42)
# DEV_ALLOWED_ORIGINS=192.168.1.42

# Email (required for production notifications)
# Brevo SMTP is preferred when BREVO_SMTP_KEY + BREVO_SMTP_LOGIN are set.
# Brevo REST API is used when BREVO_API_KEY is set (xkeysib-... key from Brevo dashboard).
# Resend and MailerSend are fallbacks when Brevo fails (auth OTP hook + app transactional mail).
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_API_KEY=
BREVO_FROM_EMAIL=orders@mithron.co
BREVO_FROM_NAME=Mithron India Smart Services Pvt Ltd
RESEND_API_KEY=
MAILERSEND_API_KEY=
EMAIL_FROM=Mithron <noreply@mithron.com>
# IMPORTANT: Brevo rejects mail if BREVO_FROM_EMAIL is not a verified sender.
# Until mithron.co is authenticated in Brevo (Domains), use the verified sender
# shown in Brevo → Senders (currently mithronadmin@gmail.com), then switch back.
# Supabase Send Email Hook secret (format v1,whsec_<base64>). Generated by npm run sync:auth-config.
AUTH_HOOK_SEND_EMAIL_SECRET=
# Use Supabase-hosted SMTP for auth OTP (recommended until hook signing is verified end-to-end).
# Set to true to route auth mail through /api/auth/hooks/send-email instead.
# SUPABASE_SEND_EMAIL_HOOK_ENABLED=true

# Distributed rate limiting (required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Auth audit client HMAC (required for anonymous failed-login telemetry in production)
AUTH_AUDIT_CLIENT_SECRET=

# Optional client observability endpoint
NEXT_PUBLIC_OBSERVABILITY_ENDPOINT=

# Error tracking (recommended before paid traffic)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Production canonical host (custom domain). Overrides default *.vercel.app when set.
# MITHRON_PRODUCTION_HOST=mithron.com

# Media CDN — Cloudflare (or other) cache hostname in front of Supabase public storage URLs
# NEXT_PUBLIC_MEDIA_CDN_ORIGIN=https://media.mithron.com

# Scale triggers (defaults keep current stack; enable only when metrics justify migration)
# MITHRON_STORAGE_PROVIDER=supabase
# MITHRON_R2_PUBLIC_ORIGIN=https://media.mithron.com
# MITHRON_SEARCH_PROVIDER=postgres
# TYPESENSE_HOST=https://typesense.example.com
# TYPESENSE_API_KEY=
# TYPESENSE_COLLECTION=mithron_products
# MITHRON_JOB_QUEUE_PROVIDER=vercel_cron
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=

# Session idle timeout used by proxy (minutes)
SESSION_TIMEOUT_MINUTES=60

# Auth providers (Google OAuth + email/password via Supabase)
AUTH_PROVIDER_GOOGLE_ENABLED=true
AUTH_PROVIDER_EMAIL_ENABLED=true
# Require enrolled MFA metadata for admin accounts after sign-in
AUTH_ADMIN_MFA_REQUIRED=false
# Supabase dashboard: enable Google provider under Authentication → Providers.
# Add these redirect URLs under Authentication → URL configuration:
#   http://127.0.0.1:3000/auth/callback
#   https://<your-production-domain>/auth/callback

# Payments (required before accepting real checkout)
PAYMENT_PROVIDER=razorpay

# Internal service tokens (use 32+ cryptographically random bytes each)
NOTIFICATION_DISPATCH_SECRET=
PAYMENT_EXPIRE_SECRET=
CRON_SECRET=
MITHRON_ASSET_UPLOAD_TOKEN=
# Set to true after canonical media backfill; retires POST /api/upload (admin media library is the supported path)
MITHRON_UPLOAD_API_RETIRED=true
HEALTH_CHECK_SECRET=

# Media upload size cap (bytes, default 52428800 = 50 MB)
MEDIA_MAX_UPLOAD_BYTES=52428800

# Internal operator accounts in demo_access_accounts (real staff emails — not throwaway logins).
# ALLOW_DEMO_SEED=true
# DEMO_ADMIN_PASSWORD=          # Only used when creating a new account or DEMO_RESET_PASSWORDS=true
# DEMO_SUPPLIER_PASSWORD=
# DEMO_WAREHOUSE_PASSWORD=
# DEMO_RESET_PASSWORDS=true     # Set only when intentionally resetting operator email passwords

# Production E2E credentials (npm run e2e:prod — never commit real passwords)
# PLAYWRIGHT_BASE_URL=https://final-mithron-deploy.vercel.app
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=
# E2E_WAREHOUSE_EMAIL=
# E2E_WAREHOUSE_PASSWORD=
# E2E_SUPPLIER_EMAIL=
# E2E_SUPPLIER_PASSWORD=
# E2E_ALLOW_MUTATIONS=false
# LIVE_ADMIN_PASSWORD=
# LIVE_SUPPLIER_PASSWORD=
# LIVE_WAREHOUSE_PASSWORD=
# NEXT_PUBLIC_STOREFRONT_GUEST_ONLY=true

# Payment provider credentials (when PAYMENT_PROVIDER=stripe or razorpay)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RAZORPAY_KEY_ID=           # Test: rzp_test_…  Live: rzp_live_…
# RAZORPAY_KEY_SECRET=       # API secret from Razorpay dashboard (NOT the webhook secret)
# RAZORPAY_WEBHOOK_SECRET=   # Required when Razorpay is enabled. Dashboard → Webhooks →
#                            # https://<your-domain>/api/payments/webhooks/razorpay
#                            # Events: payment.captured, payment.authorized, order.paid, payment.failed
# RAZORPAY_CHECKOUT_CONFIG_ID=  # Optional dashboard checkout config; when set, runtime UPI display config is skipped
# PAYMENT_ALLOW_LIVE_IN_DEV=false  # Set true only if you intentionally use rzp_live_ keys on localhost

# Cashfree (when PAYMENT_PROVIDER=cashfree or dual-provider checkout)
# CASHFREE_APP_ID=
# CASHFREE_SECRET_KEY=
# CASHFREE_WEBHOOK_SECRET=   # Required when Cashfree is enabled. Dashboard → Webhooks →
#                            # https://<your-domain>/api/payments/webhooks/cashfree
# CASHFREE_ENV=sandbox       # sandbox → https://sandbox.cashfree.com/pg | production → https://api.cashfree.com/pg

# Optional SMS (Twilio service exists but is not wired to workflows yet)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Default warehouse for checkout reservation and inventory seeding
DEFAULT_WAREHOUSE_CODE=IN-WEST-01
DEFAULT_SUPPLIER_INTAKE_WAREHOUSE_CODE=IN-WEST-01

# Wix Stores API (catalog reconciliation tooling only)
WIX_STUDIO_API_KEY=
WIX_SITE_ID=aca2c10f-62df-404a-be24-d15cc3f32d34

# Google Gemini (CMS editor AI — text rewrite + optional image generation)
# GEMINI_API_KEY=
# Default text model: Gemma 4 26B (1500 RPD, unlimited TPM on free tier)
# GEMINI_TEXT_MODEL=gemma-4-26b-a4b-it
# Alternatives:
# GEMINI_TEXT_MODEL=gemini-3.1-flash-lite
# GEMINI_TEXT_MODEL=gemma-4-31b-it
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Internal caps (fraction of Google quota): GEMINI_RATE_LIMIT_MARGIN=0.8
# Min spacing between requests: GEMINI_MIN_REQUEST_INTERVAL_MS=5000
# Batch normalize wait budget: GEMINI_BATCH_RATE_LIMIT_MAX_WAIT_MS=180000
# Fallback when GEMINI_API_KEY is unset:
# OPENAI_API_KEY=
# OPENAI_EDITOR_MODEL=gpt-4o-mini

# Groq (Mithron AI Assistant — server-only)
# GROQ_API_KEY=
# GROQ_API_KEYS=key2,key3
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# OpenRouter (AI fallback — server-only; rotate keys if exposed)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# OPENROUTER_SITE_URL=https://your-domain.com
# OPENROUTER_APP_NAME=Mithron

# Cerebras (AI fallback — server-only; rotate keys if exposed)
# CEREBRAS_API_KEY=
# CEREBRAS_MODEL=llama3.1-8b

# CMS (production: strict mode is enabled automatically when NODE_ENV=production)
# MITHRON_CMS_STRICT=true
# MITHRON_CMS_REVISION_DEBUG=true

      "destination": "https://final-mithron-deploy.vercel.app/:path*",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mithron-flight-systems-jrzz06-kbkbkh.vercel.app" }],
      "destination": "https://final-mithron-deploy.vercel.app/:path*",
      "permanent": false
    }
  ],
  "crons": [

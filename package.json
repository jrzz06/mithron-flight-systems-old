{
  "name": "mithron-flight-systems",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:webpack": "next dev --hostname 0.0.0.0 --port 3000 --webpack",
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('.next',{recursive:true,force:true});try{fs.rmSync('tsconfig.tsbuildinfo',{force:true})}catch{}\"",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:payments": "node tools/verify-payment-setup.mjs",
    "verify:payments:orders": "node tools/verify-payment-setup.mjs --create-orders",
    "e2e": "playwright test",
    "e2e:prod": "playwright test --config=playwright.production.config.ts",
    "e2e:prod:product": "playwright test tests/e2e/product.spec.ts --config=playwright.production.config.ts",
    "e2e:prod:seo": "playwright test tests/e2e/seo.spec.ts --config=playwright.production.config.ts",
    "e2e:prod:images": "playwright test tests/e2e/images.spec.ts --config=playwright.production.config.ts",
    "e2e:prod:cms": "playwright test tests/e2e/cms.spec.ts --config=playwright.production.config.ts",
    "e2e:prod:admin": "playwright test tests/e2e/admin.spec.ts --config=playwright.production.config.ts",
    "e2e:prod:warehouse": "playwright test tests/e2e/warehouse.spec.ts --config=playwright.production.config.ts",
    "e2e:prod:supplier": "playwright test tests/e2e/supplier.spec.ts --config=playwright.production.config.ts",
    "assets:extract-mithron": "node tools/extract-mithron-source-catalog.mjs",
    "assets:retrieve-process": "node tools/retrieve-process-mithron-assets.mjs",
    "assets:optimize-storefront": "node tools/optimize-storefront-images.mjs",
    "assets:optimize-upload": "node tools/optimize-upload-mithron-assets.mjs",
    "assets:optimize-catalog-showcases": "node tools/optimize-catalog-showcases.mjs",
    "assets:optimize-shelf-heroes": "node tools/optimize-shelf-heroes.mjs",
    "assets:optimize-hero-slides": "node tools/optimize-hero-slides.mjs",
    "assets:optimize-agri-mission": "node tools/optimize-agri-mission-images.mjs",

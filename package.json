    "seed:reset-demo-users": "node tools/reset-demo-users.mjs",
    "test:load": "node tools/run-load-test.mjs",
    "test:load:report": "node tools/generate-load-test-report.mjs",
    "test:e2e:control-panel-perf": "playwright test tests/e2e/control-panel-perf.spec.ts --project=desktop",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "sync:auth-config": "node tools/sync-supabase-auth-config.mjs",
    "provision:upstash": "node tools/provision-upstash-redis.mjs",
    "db:link": "node tools/ensure-supabase-link.mjs",

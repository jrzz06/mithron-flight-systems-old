    "media:ingest-external:slug": "cross-env MEDIA_INGEST_ARGS=\"--apply --slug\" vitest run tests/tool-external-media-ingest.test.ts --testTimeout=1800000",
    "media:verify-supabase": "vitest run tests/tool-verify-product-media-supabase.test.ts --testTimeout=600000",
    "media:sync-links": "vitest run tests/tool-sync-all-product-media-links.test.ts --testTimeout=600000",
    "products:audit-quality": "node --experimental-strip-types tools/audit-product-quality.ts",
    "products:fetch-wix": "node --experimental-strip-types tools/fetch-wix-catalog.ts",
    "products:audit-catalog-parity": "node --experimental-strip-types tools/audit-product-catalog-parity.ts",

    "products:sync-wix-categories:apply": "node --experimental-strip-types tools/sync-wix-category-mapping.ts --apply",
    "products:audit-wix-descriptions": "node --experimental-strip-types tools/sync-wix-description-cleanup.ts",
    "products:sync-wix-descriptions:apply": "node --experimental-strip-types tools/sync-wix-description-cleanup.ts --apply",
    "products:normalize-descriptions": "node --experimental-strip-types tools/normalize-product-descriptions.ts",
    "products:normalize-descriptions:apply": "node --experimental-strip-types tools/normalize-product-descriptions.ts --apply",
    "products:audit-wix-pricing": "node --experimental-strip-types tools/sync-wix-pricing-reconciliation.ts --refresh-wix",
    "products:sync-wix-pricing:apply": "node --experimental-strip-types tools/sync-wix-pricing-reconciliation.ts --refresh-wix --apply",
    "products:audit-wix-specs": "node --experimental-strip-types tools/sync-wix-spec-reconcile.ts",
    "products:sync-wix-specs:apply": "node --experimental-strip-types tools/sync-wix-spec-reconcile.ts --apply",
    "assets:sync-remote-map": "node tools/sync-storefront-remote-map.mjs",
    "assets:upload-mission-local": "node tools/upload-mission-local-masters.mjs",
    "assets:cleanup-home-media-rail": "node tools/cleanup-home-media-rail-orphans.mjs",
    "assets:cleanup-home-media-rail:apply": "node tools/cleanup-home-media-rail-orphans.mjs --apply",
    "cms:patch-agri": "node tools/patch-agri-cms.mjs",
    "security:verify-secrets": "node tools/verify-secrets-hygiene.mjs",
    "security:validate-boundaries": "node tools/validate-security-boundaries.mjs",
    "security:validate-boundaries:prod": "node tools/validate-security-boundaries.mjs --base-url=https://final-mithron-deploy.vercel.app",
    "validate:currency": "node tools/validate-currency-policy.mjs",
